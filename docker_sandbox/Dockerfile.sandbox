FROM python:3.11-slim

# Prevent python from writing pyc files and buffering stdout/stderr
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV MPLBACKEND=Agg

WORKDIR /sandbox

# Install system dependencies if any, then python packages
RUN pip install --no-cache-dir \
    duckdb \
    pandas \
    numpy \
    matplotlib \
    seaborn \
    openpyxl

# Entry point will run the script runner
COPY run_script.py /sandbox/run_script.py

ENTRYPOINT ["python", "/sandbox/run_script.py"]
